{
  "name": "pattern-monorepo",
  "version": "0.2.2",
  "private": true,
  "description": "Pattern — a workflow execution engine and framework foundation.",
  "type": "module",
  "engines": {
    "node": ">=22.5"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter \"./packages/**\" run typecheck",
    "dev:site": "pnpm --filter site dev",
    "build:site": "pnpm --filter site build",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo",
    "local:publish": "node scripts/verdaccio-publish.mjs",
    "local:test-create": "node scripts/verdaccio-test-create.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
