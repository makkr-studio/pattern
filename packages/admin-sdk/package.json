{
  "name": "@pattern-js/admin-sdk",
  "version": "0.2.39",
  "description": "Pattern admin SDK — the stable extension surface for admin UIs and mods (typed API client, menu/command helpers, shared protocol types).",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pattern",
    "admin",
    "sdk",
    "client"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pattern-js/mod-admin": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "typescript": "^5.6.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/admin-sdk"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
