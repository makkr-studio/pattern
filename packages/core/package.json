{
  "name": "@pattern/core",
  "version": "0.1.37",
  "description": "Pattern execution engine — runtime-neutral core (Web-standard APIs only).",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "workflow",
    "engine",
    "dataflow",
    "dag",
    "automation",
    "pattern"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ops": {
      "types": "./dist/ops-core/index.d.ts",
      "import": "./dist/ops-core/index.js"
    },
    "./boundaries": {
      "types": "./dist/boundaries/index.d.ts",
      "import": "./dist/boundaries/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
