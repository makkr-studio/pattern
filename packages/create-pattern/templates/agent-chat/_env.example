# Copied to `.env` (gitignored), loaded automatically on boot — existing
# environment variables always win over this file.

# Provider keys are set per model alias in admin → Settings → AI Providers, each
# sourced from the vault (encrypted) or an env var you name. To use an env var,
# define it here — OPENAI_API_KEY below is just a common example. The Vercel AI
# Gateway uses a single AI_GATEWAY_API_KEY instead.
OPENAI_API_KEY=

# The vault's master key. Generate ONCE: openssl rand -base64 32
# Same key forever — it decrypts .pattern-data/vault.db.
PATTERN_VAULT_KEY=

# Require sign-in to chat? Unset/false = guests welcome (device-scoped).
# true = any signed-in user; a comma-separated list = required scopes.
# CHAT_REQUIRE_AUTH=true

# Professional-conduct guardrail: a small model screens each message and trips
# on subjects not allowed at work. ON by default — set to false/0/off to drop
# it from the turn pipeline (the classifier workflow still ships, wire-by-hand).
# CHAT_GUARDRAIL=false

# Require sign-in to READ the docs at /docs? Same semantics as CHAT_REQUIRE_AUTH.
# DOCS_REQUIRE_AUTH=true
