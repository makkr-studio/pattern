{
  "id": "tool-weather",
  "name": "Tool · get_weather",
  "description": "A tool with validated arguments: the params schema is enforced by the ENGINE before this graph runs — a hallucinated argument never reaches it.",
  "nodes": [
    {
      "id": "in",
      "op": "boundary.tool",
      "config": {
        "name": "get_weather",
        "description": "Current weather for a city (one line).",
        "params": {
          "type": "object",
          "properties": { "city": { "type": "string", "description": "City name, e.g. Paris" } },
          "required": ["city"]
        }
