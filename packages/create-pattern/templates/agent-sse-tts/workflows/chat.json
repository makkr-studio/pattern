{
  "$schema": "pattern/workflow/v1",
  "id": "chat",
  "name": "GET /chat — agent → SSE + TTS",
  "description": "One token stream, two consumers: SSE pushes tokens to the browser as they arrive, while TTS waits for the accumulated full reply.",
  "nodes": [
    {
      "id": "in",
      "op": "boundary.http.request",
      "config": { "method": "GET", "path": "/chat", "cors": true },
      "comment": "Try: curl -N 'localhost:3000/chat?prompt=hi'"
    },
    { "id": "agent", "op": "agent.tokens", "comment": "Mock agent — swap for a real LLM call in mods/agent.mjs." },
    { "id": "split", "op": "core.stream.split", "config": { "branches": 2 } },
    { "id": "gather", "op": "core.stream.accumulate", "config": { "mode": "concat" }, "comment": "BARRIER: waits for the full reply." },
    { "id": "tts", "op": "agent.tts" },
    { "id": "out", "op": "boundary.http.response", "config": { "mode": "sse" } }
  ],
  "edges": [
    { "from": { "node": "in", "port": "query" }, "to": { "node": "agent", "port": "prompt" } },
    { "from": { "node": "agent", "port": "out" }, "to": { "node": "split", "port": "in" } },
    { "from": { "node": "split", "port": "out.0" }, "to": { "node": "out", "port": "stream" } },
    { "from": { "node": "split", "port": "out.1" }, "to": { "node": "gather", "port": "in" } },
    { "from": { "node": "gather", "port": "out" }, "to": { "node": "tts", "port": "text" } }
  ]
}
