{
  "$schema": "pattern/workflow/v1",
  "id": "billing-portal",
  "name": "POST /billing/portal",
  "description": "The provider\u2019s own subscription UI (upgrade, cancel, invoices, cards) for the signed-in user\u2019s customer. Durable, like everything that touches money.",
  "durable": true,
  "nodes": [
    {
      "id": "in",
      "op": "boundary.http.request",
      "config": {
        "method": "POST",
        "path": "/billing/portal",
        "requireAuth": true
      },
      "ui": {
        "x": 40,
        "y": 140
      }
    },
    {
      "id": "who",
      "op": "core.object.extract",
      "config": {
        "keys": [
          "id"
        ]
      },
      "ui": {
        "x": 300,
        "y": 80
      }
    },
    {
      "id": "portal",
      "op": "billing.portal.create",
      "config": {
        "account": "default"
      },
      "retry": {
        "attempts": 3,
        "backoffMs": 400
      },
      "ui": {
        "x": 560,
        "y": 140
      }
    },
    {
      "id": "status",
      "op": "boundary.http.status",
      "comment": "Setup-shaped outcomes (billing not configured / no customer yet) map to 409 with friendly JSON; success stays 200.",
      "ui": {
        "x": 820,
        "y": 140
      }
    },
    {
      "id": "out",
      "op": "boundary.http.response",
      "config": {
        "mode": "buffered"
      },
      "ui": {
        "x": 1080,
        "y": 140
      }
    }
  ],
  "edges": [
    {
      "from": {
        "node": "in",
        "port": "user"
      },
      "to": {
        "node": "who",
        "port": "object"
      }
    },
    {
      "from": {
        "node": "who",
        "port": "id"
      },
      "to": {
        "node": "portal",
        "port": "userId"
      }
    },
    {
      "from": {
        "node": "in",
        "port": "url"
      },
      "to": {
        "node": "portal",
        "port": "origin"
      }
    },
    {
      "from": {
        "node": "portal",
        "port": "result"
      },
      "to": {
        "node": "status",
        "port": "result"
      }
    },
    {
      "from": {
        "node": "status",
        "port": "status"
      },
      "to": {
        "node": "out",
        "port": "status"
      }
    },
    {
      "from": {
        "node": "status",
        "port": "body"
      },
      "to": {
        "node": "out",
        "port": "body"
      }
    }
  ]
}
