{
  "name": "@pattern-js/mod-admin",
  "version": "0.3.3",
  "description": "Pattern admin mod — authorable, self-reflecting control surface (control plane, workflow store, run inspection).",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pattern",
    "mod",
    "admin",
    "workflow",
    "control-plane"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "dist-app",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm build:app",
    "build:backend": "tsc -p tsconfig.json",
    "build:app": "vite build",
    "dev:app": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "@pattern-js/admin-sdk": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.11.0",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "zustand": "^5.0.14",
    "@testing-library/react": "^16.1.0",
    "@testing-library/dom": "^10.4.0",
    "happy-dom": "^15.11.0",
    "@pattern-js/mod-sample": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-admin"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
