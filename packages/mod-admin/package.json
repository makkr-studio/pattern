  },
  "dependencies": {
    "@pattern/core": "workspace:*",
    "@pattern/runtime-node": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
