{
  "name": "@pattern-js/mod-auth-oidc",
  "version": "0.4.0",
  "description": "OIDC login for Pattern — sign users in with Google, Microsoft, Keycloak or any OpenID Connect issuer. Authorization-code flow with PKCE, ID tokens verified with jose, sessions minted by mod-identity. Code-configured (a small wrapper mod); several providers side by side.",
  "keywords": [
    "pattern",
    "mod",
    "auth",
    "oidc",
    "openid-connect",
    "sso",
    "login"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/mod-identity": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "jose": "^6.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-auth-oidc"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
