{
  "name": "@pattern-js/mod-billing-stripe",
  "version": "0.4.0",
  "description": "Stripe driver for @pattern-js/mod-billing — Checkout Sessions, the Customer Portal, subscription state and Billing Meter events over a zero-dependency fetch client, plus Stripe-Signature webhook verification (raw bytes, constant-time, rotation-aware) feeding the normalized billing event pipeline.",
  "keywords": [
    "pattern",
    "mod",
    "billing",
    "stripe",
    "payments",
    "subscriptions",
    "webhooks",
    "metering"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/mod-billing": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-billing-stripe"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
