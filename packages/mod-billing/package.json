{
  "name": "@pattern-js/mod-billing",
  "version": "0.4.0",
  "description": "Payments for Pattern — the provider-neutral billing contract: named accounts with sourced secrets, hosted checkout + customer portal as ops, a normalized webhook event union with stable-id dedup, a user↔customer mapping, subscription→role entitlement projection into mod-identity, and usage metering. Providers plug in as driver mods (Stripe first).",
  "keywords": [
    "pattern",
    "mod",
    "billing",
    "payments",
    "subscriptions",
    "stripe",
    "saas",
    "entitlements",
    "metering"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-billing"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
