{
  "name": "@pattern-js/mod-buddy",
  "version": "0.3.0",
  "description": "Buddy — the in-admin workflow assistant for Pattern. A chat dock in the editor that drafts workflows, self-repairs against the validator, debugs failed runs from traces, and applies proposals to your open canvas. Its control-plane toolset (the pattern_* tools) doubles as the Pattern MCP server surface.",
  "keywords": [
    "pattern",
    "mod",
    "buddy",
    "assistant",
    "agent",
    "mcp",
    "control-plane"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/mod-agents": "workspace:*",
    "@pattern-js/mod-ai": "workspace:*",
    "@pattern-js/mod-docs": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@pattern-js/mod-admin": "workspace:*",
    "@pattern-js/mod-identity": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-buddy"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
