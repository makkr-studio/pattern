{
  "name": "@pattern-js/mod-docs",
  "version": "0.2.42",
  "description": "Self-reflecting documentation for Pattern apps: a markdown-first docs app at /docs (admin's visual language, reading-first) where every installed mod — first or third party — contributes its own chapter, the op reference is generated from the live registry, workflow code fences render as real graphs, and the whole set is agent-readable at /docs/llms.txt.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "dist-app",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm build:app",
    "build:app": "vite build",
    "dev:app": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.11.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "zustand": "^5.0.14"
  },
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-docs"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
