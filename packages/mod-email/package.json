{
  "name": "@pattern-js/mod-email",
  "version": "0.3.0",
  "description": "Transactional email for Pattern — the contract mod. Admin-configured accounts (provider + sourced secrets + from), driver mods plug in (Resend, SMTP, …), one email.send op, and a packaged workflow that delivers identity sign-in links the moment a default account exists.",
  "keywords": [
    "pattern",
    "mod",
    "email",
    "transactional-email",
    "smtp",
    "resend"
  ],
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern-js/core": "workspace:*",
    "@pattern-js/runtime-node": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@pattern-js/mod-identity": "workspace:*",
    "@pattern-js/mod-auth-magic-link": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/makkr-studio/pattern.git",
    "directory": "packages/mod-email"
  },
  "homepage": "https://github.com/makkr-studio/pattern#readme",
  "bugs": "https://github.com/makkr-studio/pattern/issues",
  "author": "Makkr Studio (https://github.com/makkr-studio)"
}
