{
  "name": "@pattern/mod-store",
  "version": "0.1.24",
  "description": "Generic persistence for Pattern apps: JSON document collections with declared indexes, a blob store, and CAS leases (with auto-release on run settle). SQLite or in-memory drivers; ops for visible canvas wiring; a Data browser in the admin.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pattern/core": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@pattern/runtime-node": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.5"
  }
}
